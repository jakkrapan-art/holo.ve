# Godot 4 imports: .import sidecars are TRACKED so asset UIDs stay stable across
# checkouts/worktrees (prevents recurring "invalid UID" warnings). Do not re-ignore
# *.import. Only the .godot/ cache below (the actual reimported binaries) is ignored.

# Godot 4 editor files
.godot/
.godot

# Godot 3 (legacy, if migrating)
.import/

# Export presets
export_presets.cfg

# Mono-specific (C# projects)
.mono/
data_*/
mono_crash.*.json

# Build results
*.translation

# Build / export artifacts (exported game builds must never be committed)
*.pck
/build/

# Temporaries
*.tmp
*.log
app
.qodo

# System-specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# IDE
.vscode/
.idea/
*.swp
*.swo
/.claude/
*.md
